# ---- Sensitive ----
MAILCOW_API_KEY=replace_with_mailcow_api_key
VALIDATION_RECEIVER_EMAIL=
VALIDATION_RECEIVER_APP_PASSWORD=

# ---- Existing script defaults ----
MAILCOW_URL=https://mail.cazehiresense.com
WEBMAIL_URL=https://mail.cazehiresense.com
MAIL_DOMAIN=cazehiresense.com
MAIL_LOCAL_PREFIX=hs
MAIL_LOCAL_LENGTH=7
MAILBOX_NAME_PREFIX=User
MAILBOX_QUOTA_MB=0
APP_PASSWORD_NAME=hiresense
PLAYWRIGHT_HEADLESS=true
SMTP_HOST=mail.cazehiresense.com
SMTP_PORT=587
SMTP_USE_TLS=true
IMAP_HOST=mail.cazehiresense.com
IMAP_PORT=993

# Notes:
# - If receiver email/password are left empty, SMTP validation will send each test email to itself.
# - If both receiver values are provided, IMAP verification is enabled against that receiver inbox.

# ---- Email Pool Encryption & Deployment ----
# Path to the db-mgmt repo on the host (mounted as /mnt/db-mgmt inside Docker)
DB_MGMT_REPO_PATH=/home/azureuser/Hire-Sense-Backend-Team/repo-csv/db-mgmt
# Base64-encoded decryption key used by encrypt_email_pool.sh
EMAIL_POOL_DECRYPT_KEY_BASE64=
